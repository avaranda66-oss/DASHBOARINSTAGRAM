# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/lib/generated/prisma

# ===== SECURITY: Sensitive files =====

# Database files
*.db
*.sqlite
prisma/dev.db

# Debug artifacts (login screenshots, logs, story debug)
public/login-*
public/debug-*
public/story-debug-*
public/diag-*
public/canvas_*

# User uploaded media (personal images, AI-generated content)
public/uploads/

# Session data (Playwright cookies, tokens)
sessions/

# Client-specific scripts (contain real data)
scripts/test-varanda-*
scripts/test-tarcila-*
scripts/inject-senior-*
scripts/inject-story-tarcila*
scripts/inject-story-test*
scripts/inject-story-v3*
scripts/diag-*
scripts/run-story-*
scripts/test-real-*
scripts/test-ai-*
